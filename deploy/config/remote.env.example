# ============================================================
# SAP Panda Next.js — Remote Server Configuration
#
# Copy this file to remote.env and adjust for your environment.
# This file is sourced by deploy-nextjs-standalone.sh.
# ============================================================

# デプロイ先サーバーのホスト名またはIPアドレス
REMOTE_SERVER=your-nextjs-server.com

# SSH 接続ユーザー名
REMOTE_USER=root

# SSH ポート
REMOTE_PORT=22

# デプロイ先ディレクトリ（サーバー上の絶対パス）
REMOTE_DEPLOY_PATH=/opt/sap-panda-nextjs

# Next.js 公開ドメイン（Nginx server_name 設定用、任意）
NEXTJS_DOMAIN=your-nextjs-domain.com
