# ============================================================
# SAP Panda Academy — react_next (Next.js SSR) 环境变量
# ============================================================
# 复制为 .env 并修改:
#   cp .env.example .env
# ============================================================

# 服务端口
PORT=3000

# WordPress 远程服务器 URL（Server Components 直接 fetch 用）
NEXT_PUBLIC_WP_URL=https://sap-navi.aladdin-techec.com

# SAP Panda REST API ベースURL
NEXT_PUBLIC_API_BASE=https://sap-navi.aladdin-techec.com/wp-json/sap/v1

# サイトの公開 URL（SEO / OGP メタタグ用）
NEXT_PUBLIC_SITE_URL=https://your-nextjs-domain.com

# Google Analytics 4 測定 ID（空欄で無効）
NEXT_PUBLIC_GA_ID=
