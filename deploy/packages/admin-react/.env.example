# ============================================================
# SAP Panda Academy — admin-react 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据环境填写：
#   cp .env.example .env
# ============================================================

# SSR 服务端口
PORT=3000

# WordPress 安装子路径
# 空字符串表示根目录安装（如 http://example.com/）
# 如果是子目录安装（如 http://example.com/sap/），则填写 /sap
SITE_BASE=

# API 基础 URL（一般留空，会自动根据 SITE_BASE 拼接）
# 仅在需要显式指定时设置
API_BASE=

# SSR 渲染开关（1=启用, 0=禁用）
SSR_ENABLED=1

# Node.js 运行模式
NODE_ENV=production
