# SAP Panda Next.js — Environment Variables
# Copy this file to .env.local and adjust for your environment

# WordPress REST API base URL（開発時は相対パス、本番は絶対URL）
NEXT_PUBLIC_API_BASE=/wp-json/sap/v1

# Full WordPress URL（開発時: http://localhost:8080、本番: https://sap-navi.aladdin-techec.com）
NEXT_PUBLIC_WP_URL=http://localhost:8080

# Site URL（開発時: http://localhost:3000、本番: https://your-nextjs-domain.com）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 — Measurement ID (例: G-XXXXXXXXXX)
# 空の場合はトラッキングコードは読み込まれません
NEXT_PUBLIC_GA_ID=
